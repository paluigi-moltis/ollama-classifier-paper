% =============================================================================
% 1. CORE SOFTWARE
% =============================================================================

@software{ollama-classifier,
  title = {ollama-classifier: A Python Library for Retrieval-Augmented
           Classification Using Local Large Language Models},
  author = {Palumbo, Luigi},
  url = {https://pypi.org/project/ollama-classifier/},
  year = {2025},
  annote = {This is the main subject of the paper. The ollama-classifier library
            implements the Retrieval-Augmented Classification (RAC) framework,
            enabling users to leverage locally-running LLMs via Ollama as
            zero-shot/few-shot classifiers without any fine-tuning. It provides
            a modular pipeline encompassing synthetic knowledge base construction,
            semantic retrieval, and generative classification, abstracting away
            the complexity of RAC for both researchers and practitioners.}
}

@software{ollama,
  title = {Ollama: Run Large Language Models Locally},
  author = {{Ollama Contributors}},
  url = {https://ollama.com},
  year = {2023},
  annote = {Ollama is the underlying runtime used by ollama-classifier to serve
            open-source LLMs (e.g., LLaMA, Mistral, Qwen, DeepSeek) on
            consumer hardware. By eliminating dependency on cloud APIs, Ollama
            provides the privacy, cost-effectiveness, and offline capability that
            are central to the library's value proposition.}
}


% =============================================================================
% 2. RETRIEVAL-AUGMENTED CLASSIFICATION & GENERATION (RAC/RAG)
% =============================================================================

@inproceedings{lewis2020retrieval,
  title = {Retrieval-Augmented Generation for Knowledge-Intensive {NLP} Tasks},
  author = {Lewis, Patrick and Perez, Ethan and Piktus, Aleksandra and
            Petroni, Fabio and Karpukhin, Vladimir and Goyal, Naman and
            K{\"u}ttler, Heinrich and Lewis, Mike and Yih, Wen-tau and
            Rockt{\"a}schel, Tim and others},
  booktitle = {Advances in Neural Information Processing Systems},
  volume = {33},
  pages = {9459--9474},
  year = {2020},
  url = {https://arxiv.org/abs/2005.11401},
  annote = {Seminal paper introducing Retrieval-Augmented Generation (RAG), which
            grounds LLM outputs in externally retrieved evidence to improve
            factuality and stability. The ollama-classifier library builds upon
            this paradigm, using retrieval to condition the generative
            classification step, improving both accuracy and interpretability
            over pure prompting approaches.}
}

@inproceedings{yu2023retrieval,
  title = {Retrieval-Augmented Few-Shot Text Classification},
  author = {Yu, Guoxin and Liu, Lemao and Jiang, Haiyun and Shi, Shuming and
            Ao, Xiang},
  booktitle = {Findings of the Association for Computational Linguistics:
               EMNLP},
  pages = {6721--6735},
  year = {2023},
  url = {https://arxiv.org/abs/2308.13314},
  annote = {Directly relevant to the classification methodology implemented in
            ollama-classifier. Demonstrates that combining nearest-neighbor
            retrieval with few-shot prompting improves text classification
            without fine-tuning, which is the core mechanism the library
            implements using Ollama-based models.}
}

@inproceedings{abdullahi2024retrieval,
  title = {Retrieval Augmented Zero-Shot Text Classification},
  author = {Abdullahi, Tassallah and Singh, Ritambhara and Eickhoff, Carsten},
  booktitle = {Proceedings of the 2024 ACM SIGIR International Conference on
               Theory of Information Retrieval},
  pages = {195--203},
  year = {2024},
  doi = {10.1145/3675118.3675148},
  annote = {Extends retrieval-augmented classification to the zero-shot setting,
            closely aligning with ollama-classifier's ability to classify into
            arbitrary taxonomies without training data. The library's approach
            of retrieving exemplars from a synthetic knowledge base reflects the
            methodology explored in this work.}
}

@article{nunes2025rac,
  title = {Classification at Scale: A Retrieval-Augmented Classification
           Framework for {COICOP} 2018 Consumer Products},
  author = {Nunes, In{\^e}s and Palumbo, Luigi and Bacco, Luca},
  journal = {Manuscript under review},
  year = {2025},
  url = {https://github.com/paluigi/ollama-classifier},
  annote = {Foundational work by the same author of ollama-classifier,
            describing the RAC framework that the library implements. This paper
            demonstrates the methodology on COICOP product classification,
            achieving up to 0.80 accuracy at the finest granularity level. The
            ollama-classifier library is the software realization of this
            framework, packaged as a general-purpose, reusable tool.}
}


