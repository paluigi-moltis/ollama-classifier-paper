}

@article{he2021automl,
  title = {{AutoML}: A Survey of the State-of-the-Art},
  author = {He, Xin and Zhao, Kai and Chu, Xiaowen},
  journal = {Knowledge-Based Systems},
  volume = {228},
  pages = {107243},
  year = {2021},
  doi = {10.1016/j.knosys.2021.107243},
  annote = {AutoML aims to automate the ML pipeline, making it accessible to
            non-experts. The ollama-classifier GUI shares this philosophy,
            abstracting the complexity of RAC---including retrieval
            configuration, embedding selection, and prompt engineering---behind
            an intuitive interface, analogous to how AutoML tools hide
            hyperparameter tuning and model selection.}
}

@article{lazaridou2023ai,
