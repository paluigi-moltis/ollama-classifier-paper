  author = {Lazaridou, Angeliki and Kobyzev, Ivan and Mahowald, Kyle and
            Mordatch, Igor and Niekum, Scott and others},
  journal = {arXiv preprint arXiv:2308.11016},
  year = {2023},
  url = {https://arxiv.org/abs/2308.11016},
  annote = {Discusses the importance of democratizing access to AI tools for
            domain experts who are not ML specialists. Relevant to the
            ollama-classifier GUI's goal of enabling non-technical users---such
            as economists, statisticians, and data officers---to leverage
            state-of-the-art LLM classification without writing code.}
}
